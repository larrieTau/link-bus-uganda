<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Link Bus Uganda | Kampala to Western Uganda – Book Online</title>
<meta name="description" content="Book Link Bus tickets online. Daily scheduled trips from Kampala to Fort Portal, Kasese, Masindi, Hoima, Bundibugyo and more. MTN & Airtel Mobile Money accepted.">
<meta name="keywords" content="Link Bus Uganda, Bus to Fort Portal, Kampala to Kasese bus, Link Bus Booking, Uganda bus tickets, Kampala courier service">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #1a6b2f;
    --green-dark: #0f4520;
    --green-mid: #2a8c42;
    --green-light: #e8f5ec;
    --yellow: #f5c500;
    --yellow-dark: #c9a000;
    --yellow-light: #fff9d6;
    --black: #0d0d0d;
    --white: #fafafa;
    --grey: #6b7280;
    --grey-light: #f3f4f6;
    --radius: 12px;
    --shadow: 0 4px 24px rgba(0,0,0,0.10);
    --shadow-lg: 0 8px 48px rgba(0,0,0,0.16);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Barlow', sans-serif;
    background: var(--white);
    color: var(--black);
    overflow-x: hidden;
  }
  h1,h2,h3,h4,h5 { font-family: 'Barlow Condensed', sans-serif; letter-spacing: 0.01em; }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: var(--green-dark);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5vw;
    height: 64px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.25);
  }
  .logo {
    display: flex; align-items: center; gap: 10px; text-decoration: none;
  }
  .logo-icon {
    width: 44px; height: 44px; background: var(--yellow);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900; font-size: 1.4rem; color: var(--green-dark);
  }
  .logo-text { color: var(--white); }
  .logo-text .brand { font-family: 'Barlow Condensed', sans-serif; font-size: 1.5rem; font-weight: 800; display: block; line-height: 1; }
  .logo-text .tagline { font-size: 0.68rem; color: var(--yellow); letter-spacing: 0.12em; text-transform: uppercase; }
  .nav-links { display: flex; gap: 28px; list-style: none; }
  .nav-links a { color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--yellow); }
  .nav-cta {
    background: var(--yellow); color: var(--green-dark);
    padding: 9px 22px; border-radius: 8px;
    font-weight: 700; font-size: 0.9rem; text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .nav-cta:hover { background: #ffe033; transform: translateY(-1px); }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; }
  .hamburger span { display: block; width: 26px; height: 2.5px; background: var(--white); border-radius: 2px; transition: all 0.3s; }

  /* ── HERO ── */
  .hero {
    background: linear-gradient(135deg, var(--green-dark) 0%, var(--green) 60%, #2e9e4f 100%);
    min-height: 92vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 60px 5vw 40px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .hero-badge {
    background: rgba(245,197,0,0.18); border: 1px solid var(--yellow);
    color: var(--yellow); padding: 6px 18px; border-radius: 100px;
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 22px;
    animation: fadeInDown 0.6s ease both;
  }
  .hero h1 {
    font-size: clamp(2.8rem, 8vw, 6.5rem);
    font-weight: 900; color: var(--white);
    text-align: center; line-height: 0.95;
    text-transform: uppercase;
    animation: fadeInUp 0.7s ease 0.1s both;
  }
  .hero h1 .yellow { color: var(--yellow); }
  .hero-sub {
    color: rgba(255,255,255,0.82); font-size: clamp(1rem, 2.5vw, 1.25rem);
    text-align: center; margin-top: 16px; max-width: 580px;
    animation: fadeInUp 0.7s ease 0.2s both;
  }

  /* ── BOOKING WIDGET ── */
  .booking-card {
    background: var(--white);
    border-radius: 20px;
    padding: 32px;
    margin-top: 40px;
    width: 100%; max-width: 820px;
    box-shadow: var(--shadow-lg);
    animation: fadeInUp 0.8s ease 0.3s both;
    position: relative; z-index: 2;
  }
  .booking-card h2 { font-size: 1.5rem; font-weight: 800; color: var(--green-dark); margin-bottom: 20px; }
  .booking-row {
    display: grid; grid-template-columns: 1fr 1fr 1fr auto;
    gap: 12px; align-items: end;
  }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field label { font-size: 0.78rem; font-weight: 700; color: var(--grey); letter-spacing: 0.07em; text-transform: uppercase; }
  .field select, .field input {
    border: 2px solid #e5e7eb; border-radius: 10px;
    padding: 12px 14px; font-family: 'Barlow', sans-serif;
    font-size: 0.95rem; color: var(--black);
    background: var(--white); outline: none;
    transition: border-color 0.2s;
    appearance: none; -webkit-appearance: none;
    cursor: pointer;
  }
  .field select:focus, .field input:focus { border-color: var(--green); }
  .search-btn {
    background: var(--green); color: var(--white);
    padding: 13px 28px; border: none; border-radius: 10px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.1rem; font-weight: 700;
    cursor: pointer; transition: background 0.2s, transform 0.15s;
    white-space: nowrap; letter-spacing: 0.04em;
  }
  .search-btn:hover { background: var(--green-dark); transform: translateY(-2px); }
  .payment-row {
    display: flex; align-items: center; gap: 14px;
    margin-top: 18px; padding-top: 18px;
    border-top: 1px solid #f0f0f0;
    flex-wrap: wrap;
  }
  .payment-row span { font-size: 0.8rem; color: var(--grey); font-weight: 500; }
  .pay-badge {
    display: flex; align-items: center; gap: 6px;
    background: var(--grey-light); border-radius: 8px;
    padding: 5px 12px; font-size: 0.8rem; font-weight: 600;
  }
  .pay-badge.mtn { background: #fff3cd; color: #856404; }
  .pay-badge.airtel { background: #ffe0e0; color: #9b1c1c; }
  .pay-badge.visa { background: #e8f0fe; color: #1a56db; }
  .dot { width: 8px; height: 8px; border-radius: 50%; }
  .dot.mtn { background: #f5c500; }
  .dot.airtel { background: #e53e3e; }
  .dot.visa { background: #1a56db; }

  /* ── QUICK STATS ── */
  .stats-bar {
    background: var(--yellow);
    padding: 22px 5vw;
    display: flex; justify-content: space-around; align-items: center;
    flex-wrap: wrap; gap: 16px;
  }
  .stat { text-align: center; }
  .stat .num { font-family: 'Barlow Condensed', sans-serif; font-size: 2.4rem; font-weight: 900; color: var(--green-dark); line-height: 1; }
  .stat .label { font-size: 0.78rem; font-weight: 600; color: var(--green); letter-spacing: 0.08em; text-transform: uppercase; }

  /* ── SECTIONS ── */
  section { padding: 80px 5vw; }
  .section-label {
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--green);
    display: block; margin-bottom: 10px;
  }
  .section-title { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 900; color: var(--green-dark); line-height: 1.05; }
  .section-sub { font-size: 1.05rem; color: var(--grey); margin-top: 12px; max-width: 540px; }

  /* ── ROUTES ── */
  .routes-section { background: var(--green-dark); }
  .routes-section .section-title { color: var(--white); }
  .routes-section .section-label { color: var(--yellow); }
  .routes-section .section-sub { color: rgba(255,255,255,0.65); }
  .routes-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px; margin-top: 40px;
  }
  .route-card {
    background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px; padding: 22px;
    cursor: pointer; transition: all 0.25s;
    position: relative; overflow: hidden;
  }
  .route-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 4px; height: 100%; background: var(--yellow);
  }
  .route-card:hover { background: rgba(255,255,255,0.13); transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0,0,0,0.3); }
  .route-from { font-size: 0.7rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }
  .route-to { font-family: 'Barlow Condensed', sans-serif; font-size: 1.6rem; font-weight: 800; color: var(--white); margin: 4px 0; }
  .route-meta { display: flex; gap: 12px; margin-top: 12px; }
  .route-tag {
    font-size: 0.72rem; font-weight: 600; padding: 3px 10px;
    border-radius: 100px; background: rgba(245,197,0,0.18); color: var(--yellow);
    letter-spacing: 0.04em;
  }
  .route-price { font-family: 'Barlow Condensed', sans-serif; font-size: 1.1rem; font-weight: 700; color: var(--yellow); margin-top: 10px; }

  /* ── FLEET ── */
  .fleet-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 50px; align-items: center; }
  .fleet-visual {
    background: linear-gradient(135deg, var(--green) 0%, var(--green-dark) 100%);
    border-radius: 20px; padding: 50px 30px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 340px;
    position: relative; overflow: hidden;
  }
  .bus-svg { width: 100%; max-width: 380px; }
  .fleet-features { display: flex; flex-direction: column; gap: 20px; }
  .fleet-feature {
    display: flex; align-items: flex-start; gap: 16px;
    padding: 20px; border-radius: 14px;
    background: var(--white); border: 1.5px solid #eee;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .fleet-feature:hover { border-color: var(--green); box-shadow: 0 4px 16px rgba(26,107,47,0.1); }
  .feature-icon {
    width: 46px; height: 46px; border-radius: 10px;
    background: var(--green-light); display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; flex-shrink: 0;
  }
  .feature-title { font-family: 'Barlow Condensed', sans-serif; font-size: 1.15rem; font-weight: 700; color: var(--green-dark); }
  .feature-desc { font-size: 0.88rem; color: var(--grey); margin-top: 3px; }

  /* ── SCHEDULE ── */
  .schedule-section { background: var(--grey-light); }
  .schedule-table-wrap { margin-top: 36px; overflow-x: auto; border-radius: 14px; box-shadow: var(--shadow); }
  table { width: 100%; border-collapse: collapse; background: var(--white); font-size: 0.92rem; }
  thead { background: var(--green-dark); }
  th { color: var(--white); padding: 14px 18px; text-align: left; font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; font-weight: 700; letter-spacing: 0.05em; white-space: nowrap; }
  td { padding: 13px 18px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--green-light); }
  .status-pill {
    padding: 4px 12px; border-radius: 100px;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
  }
  .status-pill.departed { background: #e8f5ec; color: var(--green); }
  .status-pill.ontime { background: #e8f0fe; color: #1a56db; }
  .status-pill.delayed { background: #fff3cd; color: #856404; }

  /* ── SERVICES ── */
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-top: 40px; }
  .service-card {
    border-radius: 16px; overflow: hidden;
    box-shadow: var(--shadow); transition: transform 0.25s, box-shadow 0.25s;
  }
  .service-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
  .service-card .card-top { padding: 30px 28px 20px; }
  .service-card.passenger .card-top { background: linear-gradient(135deg, var(--green) 0%, var(--green-dark) 100%); }
  .service-card.courier .card-top { background: linear-gradient(135deg, #1a3d6b 0%, #0f2a50 100%); }
  .service-card.advertising .card-top { background: linear-gradient(135deg, #6b2f1a 0%, #4a1f0f 100%); }
  .service-icon { font-size: 2.2rem; margin-bottom: 12px; }
  .service-title { font-family: 'Barlow Condensed', sans-serif; font-size: 1.7rem; font-weight: 800; color: var(--white); }
  .service-sub { color: rgba(255,255,255,0.7); font-size: 0.88rem; margin-top: 6px; }
  .card-body { padding: 22px 28px; background: var(--white); }
  .card-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .card-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 0.9rem; color: var(--black); }
  .card-list li::before { content: '✓'; color: var(--green); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
  .card-cta {
    display: inline-block; margin-top: 18px;
    background: var(--green); color: var(--white);
    padding: 10px 22px; border-radius: 8px;
    font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; font-weight: 700;
    text-decoration: none; transition: background 0.2s;
  }
  .service-card.courier .card-cta { background: #1a3d6b; }
  .service-card.advertising .card-cta { background: #6b2f1a; }
  .card-cta:hover { opacity: 0.88; }

  /* ── COURIER RATES ── */
  .rates-section { background: var(--green-dark); }
  .rates-section .section-title { color: var(--white); }
  .rates-section .section-label { color: var(--yellow); }
  .rates-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 40px; }
  .rate-card {
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 14px; padding: 26px; text-align: center;
  }
  .rate-icon { font-size: 2rem; margin-bottom: 10px; }
  .rate-name { font-family: 'Barlow Condensed', sans-serif; font-size: 1.3rem; font-weight: 700; color: var(--white); }
  .rate-price { font-size: 1.7rem; font-weight: 800; color: var(--yellow); font-family: 'Barlow Condensed', sans-serif; margin: 8px 0 4px; }
  .rate-desc { font-size: 0.8rem; color: rgba(255,255,255,0.55); }

  /* ── TRUST ── */
  .trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; margin-top: 40px; }
  .trust-card {
    padding: 28px; border-radius: 16px;
    background: var(--white); border: 1.5px solid #eee;
    text-align: center; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .trust-card:hover { border-color: var(--green); box-shadow: 0 4px 20px rgba(26,107,47,0.1); }
  .trust-icon { font-size: 2.4rem; margin-bottom: 14px; }
  .trust-title { font-family: 'Barlow Condensed', sans-serif; font-size: 1.25rem; font-weight: 800; color: var(--green-dark); margin-bottom: 8px; }
  .trust-desc { font-size: 0.88rem; color: var(--grey); line-height: 1.6; }

  /* ── REVIEWS ── */
  .reviews-section { background: var(--yellow-light); }
  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 40px; }
  .review-card {
    background: var(--white); border-radius: 14px; padding: 24px;
    box-shadow: var(--shadow);
  }
  .stars { color: var(--yellow-dark); font-size: 1.1rem; margin-bottom: 10px; }
  .review-text { font-size: 0.9rem; color: #374151; line-height: 1.6; font-style: italic; }
  .reviewer { display: flex; align-items: center; gap: 10px; margin-top: 16px; }
  .reviewer-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: var(--green-light); display: flex; align-items: center; justify-content: center;
    font-family: 'Barlow Condensed', sans-serif; font-weight: 700; color: var(--green); font-size: 1rem;
  }
  .reviewer-name { font-weight: 600; font-size: 0.88rem; color: var(--black); }
  .reviewer-route { font-size: 0.75rem; color: var(--grey); }

  /* ── TERMINALS ── */
  .terminals-section { }
  .terminals-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; margin-top: 40px; }
  .terminal-card {
    border-radius: 14px; overflow: hidden;
    border: 1.5px solid #eee; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .terminal-card:hover { border-color: var(--green); box-shadow: 0 4px 16px rgba(26,107,47,0.1); }
  .terminal-header {
    padding: 18px 20px;
    background: var(--green); color: var(--white);
  }
  .terminal-header.hub { background: var(--green-dark); }
  .terminal-name { font-family: 'Barlow Condensed', sans-serif; font-size: 1.3rem; font-weight: 800; }
  .terminal-road { font-size: 0.78rem; color: rgba(255,255,255,0.7); margin-top: 2px; }
  .terminal-body { padding: 16px 20px; background: var(--white); }
  .terminal-amenities { display: flex; flex-wrap: wrap; gap: 6px; }
  .amenity { font-size: 0.72rem; padding: 3px 10px; border-radius: 100px; background: var(--green-light); color: var(--green); font-weight: 600; }

  /* ── HELP CENTER ── */
  .help-section { background: var(--grey-light); }
  .accordion { max-width: 720px; margin-top: 36px; display: flex; flex-direction: column; gap: 10px; }
  .accordion-item { background: var(--white); border-radius: 12px; border: 1.5px solid #eee; overflow: hidden; }
  .accordion-trigger {
    width: 100%; padding: 18px 22px;
    display: flex; justify-content: space-between; align-items: center;
    cursor: pointer; background: none; border: none;
    font-family: 'Barlow', sans-serif; font-size: 1rem; font-weight: 600; color: var(--black);
    text-align: left;
  }
  .accordion-trigger .icon { font-size: 1.2rem; transition: transform 0.3s; }
  .accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
  .accordion-content.open { max-height: 400px; }
  .accordion-inner { padding: 0 22px 20px; font-size: 0.92rem; color: var(--grey); line-height: 1.7; }
  .accordion-inner ul { padding-left: 18px; margin-top: 8px; }
  .accordion-inner li { margin-bottom: 5px; }

  /* ── CTA BANNER ── */
  .cta-banner {
    background: linear-gradient(135deg, var(--yellow) 0%, #ffe033 100%);
    padding: 70px 5vw; text-align: center;
  }
  .cta-banner h2 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: var(--green-dark); }
  .cta-banner p { font-size: 1.1rem; color: var(--green); margin-top: 10px; margin-bottom: 30px; }
  .cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    background: var(--green-dark); color: var(--white);
    padding: 15px 36px; border-radius: 10px;
    font-family: 'Barlow Condensed', sans-serif; font-size: 1.2rem; font-weight: 700;
    text-decoration: none; transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--green); transform: translateY(-2px); }
  .btn-secondary {
    background: rgba(15,69,32,0.12); color: var(--green-dark);
    padding: 15px 36px; border-radius: 10px;
    font-family: 'Barlow Condensed', sans-serif; font-size: 1.2rem; font-weight: 700;
    text-decoration: none; border: 2px solid var(--green-dark);
    transition: background 0.2s;
  }
  .btn-secondary:hover { background: rgba(15,69,32,0.22); }

  /* ── WHATSAPP ── */
  .whatsapp-float {
    position: fixed; bottom: 28px; right: 24px; z-index: 999;
    width: 60px; height: 60px; border-radius: 50%;
    background: #25d366; box-shadow: 0 4px 20px rgba(37,211,102,0.4);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    animation: pulse 2.5s ease infinite;
  }
  .whatsapp-float:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(37,211,102,0.55); }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 4px 20px rgba(37,211,102,0.4); }
    50% { box-shadow: 0 4px 36px rgba(37,211,102,0.7); }
  }

  /* ── FOOTER ── */
  footer {
    background: var(--black); color: rgba(255,255,255,0.65);
